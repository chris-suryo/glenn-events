# Supabase — find these in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — only for dev scripts (seed, migrations)
# NEVER expose this in client code or commit to version control
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo/dev seed — optional, used by scripts/seed.ts
SEED_USER_EMAIL=dev@example.com
SEED_USER_PASSWORD=devpassword123
