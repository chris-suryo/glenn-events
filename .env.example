# Supabase — find these in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Service role key — only for dev scripts (seed, migrations)
# NEVER expose this in client code or commit to version control
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Demo/dev seed — optional, used by scripts/seed-demo.ts
SEED_USER_EMAIL=demo@example.com
SEED_USER_PASSWORD=change-this-password
