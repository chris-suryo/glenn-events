# Supabase — find these in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Service role key — only for dev scripts (seed, migrations)
# NEVER expose this in client code or commit to version control
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Anthropic — required for real LLM extraction (Phase 7)
# Falls back to deterministic mock extractor if not set
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Sentry — optional, for error monitoring in production
# Create a project at sentry.io → Settings → Projects → [project] → Client Keys
# Falls back to no-op if DSN is not set
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID
# Required only for source map uploads during CI builds (not needed locally)
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# Demo/dev seed — optional, used by scripts/seed-demo.ts
SEED_USER_EMAIL=demo@example.com
SEED_USER_PASSWORD=change-this-password
